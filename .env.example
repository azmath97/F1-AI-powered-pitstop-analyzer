# Shared
APP_ENV=local
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me

# Backend
API_HOST=0.0.0.0
API_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATABASE_URL=postgresql+asyncpg://f1_app:f1_app_password@postgres:5432/f1_strategy
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=replace-me

# PostgreSQL
POSTGRES_DB=f1_strategy
POSTGRES_USER=f1_app
POSTGRES_PASSWORD=f1_app_password

# ML and experiment tracking
MLFLOW_TRACKING_URI=http://mlflow:5000
MODEL_REGISTRY_STAGE=Development

# Data engineering
FASTF1_CACHE_DIR=.cache/fastf1
OPENF1_BASE_URL=https://api.openf1.org/v1
ETL_START_YEAR=2018
ETL_END_YEAR=2026
ETL_BATCH_SIZE=1000
ETL_MAX_RETRIES=3
ETL_TELEMETRY_ENABLED=true
ETL_REPORT_DIR=datasets/reports
DATASET_OUTPUT_DIR=datasets/processed
